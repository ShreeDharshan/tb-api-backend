# Core app settings
APP_NAME=TB API Backend
APP_VERSION=1.1.0
APP_DEBUG=false
LOG_LEVEL=INFO

# Comma-separated list or *
CORS_ALLOW_ORIGINS=*

# Account mapping for multi-tenant setups (JSON object)
# Example: {"account1":"https://thingsboard.cloud","account2":"https://tb.example.com"}
TB_ACCOUNTS={"account1":"https://thingsboard.cloud"}

# Single-account fallback when TB_ACCOUNTS is omitted
TB_BASE_URL=https://thingsboard.cloud

# Admin credentials per account key (uppercased key)
ACCOUNT1_ADMIN_USER=tenant@tenant.org
ACCOUNT1_ADMIN_PASS=tenant

# Scheduler and report behavior
ENABLE_ALARM_SCHEDULER=true
TB_SCHEDULER_INTERVAL=30
REPORT_DIR=/tmp
